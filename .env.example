# Copy to .env and fill your real key.
# Example:
#   cp .env.example .env

# Choose provider: openai | gemini | ollama
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=example_openai_key
OPENAI_MODEL=gpt-5.2

# Gemini (used when LLM_PROVIDER=gemini)
GEMINI_API_KEY=example_gemini_key
GEMINI_MODEL=gemini-2.5-flash

# Ollama local (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

OPENAI_MAX_RETRIES=2
OPENAI_TIMEOUT_SEC=20

# Logging
MIDI_AGENT_METRICS_PATH=/tmp/midi_agent_metrics.jsonl
LLM_RAW_LOG_PATH=/tmp/midi_agent_llm_raw.jsonl
MIDI_AGENT_TERM_LOG_PATH=/tmp/midi_agent_terminal.log
LLM_ECHO_IO=true

# Save validated successful agent chunks
MIDI_AGENT_SAVE_SUCCESS_MIDI=true
MIDI_AGENT_SUCCESS_MIDI_DIR=/tmp/midi_agent_success_midi
