# Copy to .env and fill your real keys.
#   cp .env.example .env

# =========================
# Agent runtime config
# =========================
LLM_PROVIDER=openai

# Agent OpenAI (used only when LLM_PROVIDER=openai)
OPENAI_API_KEY=example_openai_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Agent Gemini (used only when LLM_PROVIDER=gemini)
GEMINI_API_KEY=example_gemini_key
GEMINI_MODEL=gemini-2.5-flash

# Agent Ollama (used only when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

OPENAI_MAX_RETRIES=2
OPENAI_TIMEOUT_SEC=20

MIDI_AGENT_METRICS_PATH=/tmp/midi_agent_metrics.jsonl
LLM_RAW_LOG_PATH=/tmp/midi_agent_llm_raw.jsonl
MIDI_AGENT_TERM_LOG_PATH=/tmp/midi_agent_terminal.log
LLM_ECHO_IO=true
MIDI_AGENT_SAVE_SUCCESS_MIDI=true
MIDI_AGENT_SUCCESS_MIDI_DIR=/tmp/midi_agent_success_midi

# =========================
# Benchmark suite config (separate from Agent)
# =========================
# One unified model list:
#   ollama:qwen2.5:7b,openai:gpt-4o-mini,gemini:gemini-2.5-flash
BENCHMARK_MODELS=ollama:qwen2.5:7b,openai:gpt-4o-mini,gemini:gemini-2.5-flash
BENCHMARK_MODEL_DEFAULT_PROVIDER=ollama

# What to generate
BENCHMARK_TASK_GROUPS=label,sequence
BENCHMARK_TOKENIZERS=note_level,midilike,remilike
BENCHMARK_RUN_MODELS=1

# OpenAI for benchmark models
BENCHMARK_OPENAI_API_KEY=example_benchmark_openai_key
BENCHMARK_OPENAI_BASE_URL=

# Gemini for benchmark models
BENCHMARK_GEMINI_API_KEY=example_benchmark_gemini_key
BENCHMARK_GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta

# Shared runner switches (ollama + api)
BENCHMARK_OUT_DIR=benchmark/results/suite
BENCHMARK_MAX_CASES=0
BENCHMARK_TIMEOUT_SEC=120
BENCHMARK_TEMP=0
BENCHMARK_SLEEP_SEC=0
BENCHMARK_SAVE_PARTIAL_ON_TIMEOUT=1
