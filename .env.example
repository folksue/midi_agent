# Copy to .env and fill your real keys.
#   cp .env.example .env

# =========================
# Agent runtime config
# =========================
LLM_PROVIDER=openai

# Shared API keys (used by both agent and benchmark scripts)
OPENAI_API_KEY=example_openai_key
OPENAI_BASE_URL=
GEMINI_API_KEY=example_gemini_key
GEMINI_API_ENDPOINT=https://generativelanguage.googleapis.com/v1beta

# Agent model selection
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.5-flash

# Agent Ollama (used only when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

OPENAI_MAX_RETRIES=2
OPENAI_TIMEOUT_SEC=20

MIDI_AGENT_METRICS_PATH=/tmp/midi_agent_metrics.jsonl
LLM_RAW_LOG_PATH=/tmp/midi_agent_llm_raw.jsonl
MIDI_AGENT_TERM_LOG_PATH=/tmp/midi_agent_terminal.log
LLM_ECHO_IO=true
MIDI_AGENT_SAVE_SUCCESS_MIDI=true
MIDI_AGENT_SUCCESS_MIDI_DIR=/tmp/midi_agent_success_midi

# Benchmark suite options are configured directly in:
# benchmark/scripts/run_ollama_bench_suite.sh
